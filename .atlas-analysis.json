  "keyFeatures": [
    "WebSocket-based communication with WhatsApp Web",
    "Multi-device authentication via QR code or pairing code",
    "Send and receive all message types (text, media, polls, reactions)",
    "Group management and participant operations",
    "Event-driven architecture with typed events",
    "Built-in message store and session management",
    "Privacy settings and profile management",
    "Broadcast lists and status/stories support",
    "TypeScript support with full type definitions"
  ],
